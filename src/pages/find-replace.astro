---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import FindReplace from '../components/tools/FindReplace';
---

<BaseLayout>
  <SEO slot="head" title="Find & Replace" description="Find and replace text with support for case-sensitive and regex matching." />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Find & Replace</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-6">Find & Replace</h1>

    <FindReplace client:load />

    <AdSense slot="bottom" />
  </div>
</BaseLayout>
