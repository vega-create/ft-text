---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import RemoveDuplicates from '../components/tools/RemoveDuplicates';
---

<BaseLayout>
  <SEO slot="head" title="Remove Duplicate Lines" description="Remove duplicate lines from your text with case-sensitive options." />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Remove Duplicate Lines</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-6">Remove Duplicate Lines</h1>

    <RemoveDuplicates client:load />

    <AdSense slot="bottom" />
  </div>
</BaseLayout>
