---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import HtmlEncode from '../components/tools/HtmlEncode';
---

<BaseLayout>
  <SEO slot="head" title="HTML Encoder / Decoder" description="Encode special characters to HTML entities or decode them back to text." />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">HTML Encoder / Decoder</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-6">HTML Encoder / Decoder</h1>

    <HtmlEncode client:load />

    <AdSense slot="bottom" />
  </div>
</BaseLayout>
