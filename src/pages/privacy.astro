---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
---
<BaseLayout>
  <SEO slot="head" title="Privacy Policy" description="Privacy policy for FreeToolkit Text." />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Privacy Policy</h1>
    <p class="text-sm text-gray-500 mb-8">Last updated: February 2026</p>
    <div class="prose prose-gray max-w-none">
      <h2>Information We Collect</h2>
      <p>FreeToolkit Text does not collect any personal information. All text processing is performed entirely in your browser. We do not store, transmit, or log any text you enter into our tools.</p>
      <h2>Analytics</h2>
      <p>We use Google Analytics to understand how visitors use our site. This service may collect anonymous data such as your browser type, device type, pages visited, and approximate geographic location.</p>
      <h2>Advertising</h2>
      <p>We use Google AdSense to display advertisements. You can opt out of personalized advertising by visiting <a href="https://www.google.com/settings/ads" class="text-primary-500">Google Ad Settings</a>.</p>
      <h2>Cookies</h2>
      <p>Our site uses cookies for analytics and advertising purposes. You can control cookies through your browser settings.</p>
      <h2>Contact</h2>
      <p>If you have questions, please contact us at <a href="mailto:contact@freetoolkit.cc" class="text-primary-500">contact@freetoolkit.cc</a>.</p>
    </div>
  </div>
</BaseLayout>
