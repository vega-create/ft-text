---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import WhitespaceCleaner from '../components/tools/WhitespaceCleaner';
---

<BaseLayout>
  <SEO slot="head" title="Whitespace Cleaner" description="Remove extra spaces, tabs, blank lines, and trim whitespace from text." />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Whitespace Cleaner</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-6">Whitespace Cleaner</h1>

    <WhitespaceCleaner client:load />

    <AdSense slot="bottom" />
  </div>
</BaseLayout>
