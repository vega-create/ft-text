---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
---
<BaseLayout>
  <SEO slot="head" title="About Us" description="Learn about FreeToolkit Text — free online text processing tools for everyone." />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">About FreeToolkit Text</h1>
    <div class="prose prose-gray max-w-none">
      <p>FreeToolkit Text provides free, fast, and privacy-friendly text processing tools for everyone. Whether you need to count words, convert case, encode URLs, or clean up messy text, our tools deliver instant results right in your browser.</p>
      <h2>Our Mission</h2>
      <p>We believe essential text tools should be free and accessible. All processing happens in your browser — your text is never sent to any server. No downloads, no sign-ups, no data collection.</p>
      <h2>What We Offer</h2>
      <p>Our toolkit includes 15 specialized text tools across five categories: analysis, transformation, encoding, formatting, and generation. Each tool is designed for speed and simplicity.</p>
      <h2>Part of FreeToolkit</h2>
      <p>FreeToolkit Text is part of the <a href="https://freetoolkit.cc" class="text-primary-500 hover:text-primary-600">FreeToolkit</a> family of free online tools including calculators, converters, and more.</p>
    </div>
  </div>
</BaseLayout>
